---
import Base from '../../layouts/Base.astro';
import PropertyCard from '../PropertyCard.astro';
import LeadForm from '../LeadForm.astro';
import { getEmpreendimentos } from '../../lib/properties';
import { consultor, whatsappUrl } from '../../config/consultor';
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'pt' } = Astro.props;
const t = useTranslations(lang);
const empreendimentos = getEmpreendimentos(lang);
const nowrap = lang === 'pt' ? 'whitespace-nowrap' : '';
---

<Base lang={lang}>
  <!-- ════════════════════════ HERO ════════════════════════ -->
  <section class="relative h-[100svh] min-h-[640px] max-h-[900px] w-full overflow-hidden bg-ink">
    <div class="absolute inset-0">
      <picture class="block h-full">
        <source media="(min-width: 768px)" srcset="/images/hero/salvador-220-night-desktop.webp" />
        <img
          src="/images/hero/salvador-220-night-mobile.webp"
          alt="Salvador 220 à noite, com o mar em primeiro plano"
          class="hero-img w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-ink/40 via-ink/45 to-ink/85"></div>

    <!-- Numeração lateral editorial (desktop) -->
    <div class="hidden md:flex absolute top-0 bottom-32 left-6 lg:left-10 items-end pointer-events-none">
      <div class="flex flex-col items-center gap-3 text-cream-50/45">
        <span class="block w-px h-20 bg-gradient-to-t from-gold/40 to-transparent"></span>
        <span class="text-[10px] uppercase tracking-[0.35em] font-medium">01 / 05</span>
      </div>
    </div>

    <div class="relative h-full container-x flex flex-col justify-end pb-32 sm:pb-32 md:pb-36 lg:pb-40">
      <p class="hero-eyebrow text-gold mb-7 animate-fade-up opacity-0" style="animation-delay:0.3s">
        <span class="opacity-60">01</span> &nbsp;—&nbsp; {t('hero_eyebrow')}
      </p>

      <h1 class="hero-title font-serif text-cream-50 leading-[0.95] max-w-5xl animate-fade-up opacity-0" style="animation-delay:0.5s">
        <span class={nowrap}>{t('hero_title_lead')} <em class="text-gold italic">{t('hero_title_em')}</em></span>
      </h1>

      <p class="hero-lead mt-10 md:mt-8 max-w-xl text-cream-50/85 font-light animate-fade-up opacity-0" style="animation-delay:0.75s">
        {t('hero_lead_pre')} <span class="text-gold">{t('hero_lead_gold')}</span> {t('hero_lead_post')}
      </p>

      <div class="hero-cta-group mt-14 md:mt-12 flex flex-wrap items-center gap-5 animate-fade-up opacity-0" style="animation-delay:1s">
        <a href="#empreendimentos" class="hero-cta-primary inline-flex items-center gap-3 bg-gold text-ink px-8 py-4 uppercase text-xs tracking-[0.2em] font-medium hover:bg-gold-400">
          {t('hero_cta_primary')}
          <span aria-hidden="true">↓</span>
        </a>
        <a href={whatsappUrl(lang)} target="_blank" rel="noopener" class="hero-contact-link hero-cta-secondary">
          {t('hero_cta_secondary').replace('{nome}', consultor.primeiroNome)}
        </a>
      </div>
    </div>

    <!-- Scroll indicator (desktop) -->
    <div class="hidden md:flex absolute bottom-8 right-6 lg:right-10 flex-col items-center gap-3 text-cream-50/55 animate-fade-in opacity-0" style="animation-delay:1.4s">
      <span class="text-[10px] uppercase tracking-[0.35em]">{t('scroll')}</span>
      <span class="block w-px h-14 bg-gradient-to-b from-gold/70 to-transparent"></span>
    </div>
  </section>

  <!-- ─── SEPARATOR 02 ─── -->
  <div class="separator-band bg-cream-50">
    <span class="separator-line"></span>
    <span class="separator-num">02 · {t('label_apresentacao')}</span>
  </div>

  <!-- ════════════════════════ APRESENTAÇÃO ════════════════════════ -->
  <section class="py-24 md:py-32 bg-cream-50">
    <div class="container-x grid lg:grid-cols-12 gap-16 lg:gap-24 items-start">
      <div class="lg:col-span-5 reveal">
        <span class="block h-px w-12 bg-gold mb-8"></span>
        <p class="eyebrow mb-6"><span class="text-gold-600">02</span> &nbsp;—&nbsp; {t('label_apresentacao')}</p>
        <h2 class="font-serif leading-[1.05]" style="font-size: clamp(2rem, 4.5vw, 3.4rem);">
          {t('apres_title_l1')}<br /> {t('apres_title_l2')}
        </h2>
      </div>
      <div class="lg:col-span-7 lg:pt-4 space-y-6 reveal">
        <p class="text-lg md:text-xl text-ink font-light leading-[1.7]">
          {t('consultor_bio')}
        </p>
        <p class="text-lg md:text-xl text-ink font-light leading-[1.7]">
          {t('apres_p2')}
        </p>
        <div class="pt-4 flex flex-wrap items-center gap-6">
          <a href={whatsappUrl(lang)} target="_blank" rel="noopener" class="btn-primary">
            {t('cta_wpp')}
            <span aria-hidden="true">→</span>
          </a>
          <a href="#sobre" class="link-underline">{t('apres_link_sobre').replace('{nome}', consultor.primeiroNome)}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SEPARATOR 03 ─── -->
  <div class="separator-band bg-cream-100">
    <span class="separator-line"></span>
    <span class="separator-num">03 · {t('nav_sobre')}</span>
  </div>

  <!-- ════════════════════════ SOBRE ════════════════════════ -->
  <section id="sobre" class="py-20 md:py-28 bg-cream-100">
    <div class="container-x grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-6 order-2 lg:order-1">
        <span class="block h-px w-12 bg-gold mb-8 reveal"></span>
        <p class="eyebrow mb-5 reveal"><span class="text-gold-600">03</span> &nbsp;—&nbsp; {t('nav_sobre')}</p>
        <h2
          class="font-serif leading-[1.02] mb-8 reveal whitespace-nowrap"
          style="font-size: clamp(1.5rem, 5vw, 3.2rem);"
        >
          {consultor.nome}.
        </h2>
        <p class="text-lg md:text-xl text-ink font-light leading-[1.7] mb-6 reveal">
          {t('sobre_p1')}
        </p>
        <div class="mt-8 grid grid-cols-2 gap-6 reveal">
          <div>
            <p class="eyebrow text-gold-600 mb-2">{t('label_registro')}</p>
            <p class="font-serif text-xl md:text-2xl">{consultor.creci}</p>
          </div>
          <div>
            <p class="eyebrow text-gold-600 mb-2">{t('label_atuacao')}</p>
            <p class="font-serif text-xl md:text-2xl">Salvador / BA</p>
          </div>
        </div>
        <div class="mt-10 flex flex-wrap gap-5 reveal">
          <a href={whatsappUrl(lang)} target="_blank" rel="noopener" class="btn-primary">
            {t('cta_wpp')}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 lg:col-start-8 order-1 lg:order-2 reveal">
        <div class="consultor-frame relative max-w-[440px] mx-auto">
          <div class="img-zoom-wrap aspect-[3/4] bg-ink-800 relative">
            <img src={consultor.foto} alt={consultor.nome} class="w-full h-full object-cover object-center" loading="lazy" />
            <div class="absolute bottom-4 left-4 right-4 bg-cream-50/95 backdrop-blur-sm px-4 py-3 md:px-5 md:py-4">
              <p class="eyebrow text-gold-600 mb-1.5 text-[10px]">{t('label_especialista')} · Salvador</p>
              <p
                class="font-serif leading-snug"
                style="font-size: clamp(0.72rem, 1.45vw, 0.92rem);"
              >{t('consultor_quote')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Diferenciais editoriais -->
    <div class="container-x mt-24 md:mt-28 grid md:grid-cols-3 gap-12 md:gap-14">
      {[
        { n: '01', t: t('home_dif1_t'), d: t('home_dif1_d') },
        { n: '02', t: t('home_dif2_t'), d: t('home_dif2_d') },
        { n: '03', t: t('home_dif3_t'), d: t('home_dif3_d') },
      ].map((item, i) => (
        <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
          <span class="block h-px w-8 bg-gold mb-6"></span>
          <p class="text-[11px] uppercase tracking-[0.3em] text-gold-600 font-medium mb-5">{item.n} · {t('label_diferencial')}</p>
          <h3 class="font-serif text-2xl md:text-3xl leading-tight mb-4">{item.t}</h3>
          <p class="text-ink-500 leading-[1.7]">{item.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── SEPARATOR 04 ─── -->
  <div class="separator-band bg-cream-50">
    <span class="separator-line"></span>
    <span class="separator-num">04 · {t('label_portfolio')}</span>
  </div>

  <!-- ════════════════════════ EMPREENDIMENTOS ════════════════════════ -->
  <section id="empreendimentos" class="py-20 md:py-28 bg-cream-50">
    <div class="container-x">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-20 md:mb-28 reveal">
        <div class="max-w-2xl">
          <span class="block h-px w-16 bg-gold mb-8"></span>
          <p class="eyebrow mb-6"><span class="text-gold-600">04</span> &nbsp;—&nbsp; {t('label_portfolio')} · {empreendimentos.length} {t('portfolio_count_suffix')}</p>
          <h2 class="font-serif text-4xl md:text-6xl leading-[1.02]">
            {t('portfolio_title_l1')}<br /> {t('portfolio_title_l2')}
          </h2>
        </div>
        <p class="text-ink-500 max-w-sm text-sm leading-[1.7]">
          {t('portfolio_desc')}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-5 md:gap-7 xl:gap-8">
        {empreendimentos.map((e, i) => <PropertyCard e={e} index={i} lang={lang} />)}
      </div>
    </div>
  </section>

  <!-- ─── SEPARATOR 05 ─── -->
  <div class="separator-band bg-ink text-cream-50/55">
    <span class="separator-line gold"></span>
    <span class="separator-num">05 · {t('nav_contato')}</span>
  </div>

  <!-- ════════════════════════ CONTATO ════════════════════════ -->
  <section id="contato" class="py-24 md:py-32 bg-ink text-cream-50">
    <div class="container-x grid lg:grid-cols-12 gap-12 lg:gap-20">
      <div class="lg:col-span-5 reveal">
        <span class="block h-px w-12 bg-gold mb-8"></span>
        <p class="eyebrow text-gold mb-6"><span class="opacity-60">05</span> &nbsp;—&nbsp; {t('nav_contato')}</p>
        <h2 class="font-serif text-4xl md:text-6xl leading-[1.02] mb-8 tracking-tight">
          {t('contato_title_l1')}<br /> {t('contato_title_l2')}
        </h2>
        <p class="text-cream-50/70 leading-[1.7] mb-12 max-w-md">
          {t('contato_desc')}
        </p>
        <div class="space-y-6">
          <a href={whatsappUrl(lang)} target="_blank" rel="noopener" class="contact-item flex border-l-2 border-gold pl-5 py-1 hover:border-gold-400 transition-colors group">
            <span>
              <span class="block text-[10px] uppercase tracking-[0.3em] text-cream-50/55 mb-1">{t('label_whatsapp')}</span>
              <span class="block text-lg group-hover:text-gold transition-colors">{consultor.whatsappFormatado}</span>
            </span>
          </a>
          <a href={`mailto:${consultor.email}`} class="contact-item flex border-l-2 border-gold pl-5 py-1 hover:border-gold-400 transition-colors group">
            <span class="break-all">
              <span class="block text-[10px] uppercase tracking-[0.3em] text-cream-50/55 mb-1">{t('label_email')}</span>
              <span class="block text-base md:text-lg group-hover:text-gold transition-colors">{consultor.email}</span>
            </span>
          </a>
        </div>
      </div>
      <div class="lg:col-span-7 bg-cream-50 text-ink p-8 md:p-12 border-t-2 border-gold reveal">
        <h3 class="font-serif text-2xl md:text-3xl mb-2">{t('form_box_title')}</h3>
        <p class="text-ink-500 text-sm mb-8">{t('form_box_sub')}</p>
        <LeadForm lang={lang} />
      </div>
    </div>
  </section>
</Base>

<style>
  /* ── HERO ───────────────────────────────────────── */
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 43% center;
  }
  @media (min-width: 768px) {
    .hero-img { object-position: center center; }
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: -0.01em;
  }
  @media (max-width: 767px) {
    .hero-title { margin-left: -1.25rem; }
    .hero-eyebrow { position: relative; top: -2rem; }
  }

  .hero-eyebrow {
    font-family: 'Inter', system-ui, sans-serif;
    text-transform: uppercase;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.3em;
  }
  @media (min-width: 768px) {
    .hero-eyebrow { font-size: 13px; letter-spacing: 0.32em; }
  }

  .hero-lead {
    font-size: clamp(0.95rem, 1.4vw, 1.125rem);
    line-height: 1.7;
  }

  .hero-cta-primary {
    transition: gap 220ms ease-out, background-color 220ms ease-out, transform 220ms ease-out;
  }
  .hero-cta-primary:hover { gap: 1.25rem; }
  .hero-cta-primary span[aria-hidden] { transition: transform 220ms ease-out; }
  .hero-cta-primary:hover span[aria-hidden] { transform: translateY(2px); }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #FBFAF6;
    border-bottom: 1px solid rgba(251, 250, 246, 0.4);
    padding-bottom: 0.35rem;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    transition: border-color 280ms ease-out, color 280ms ease-out, gap 220ms ease-out;
  }
  .hero-cta-secondary:hover {
    border-color: #C9A961;
    color: #C9A961;
    gap: 1rem;
  }

  @media (max-width: 767px) {
    .hero-cta-group {
      align-items: flex-start;
      flex-direction: column;
      gap: 0;
    }
    .hero-contact-link {
      align-self: flex-start;
      margin-left: clamp(4.5rem, 32vw, 8rem);
      margin-top: 2rem;
      white-space: nowrap;
    }
  }

  /* ── SEPARATOR BAND ─────────────────────────────── */
  .separator-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2.5rem 1rem;
  }
  .separator-num {
    font-family: 'Inter', system-ui, sans-serif;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.35em;
    color: #A88B47;
    font-weight: 500;
  }
  .separator-band.bg-ink .separator-num { color: rgba(251, 250, 246, 0.55); }
  .separator-line {
    display: block;
    height: 1px;
    width: 80px;
    background-color: rgba(201, 169, 97, 0.4);
  }
  .separator-line.gold {
    background: linear-gradient(to right, transparent, rgba(201, 169, 97, 0.7), transparent);
  }
  @media (min-width: 768px) {
    .separator-band { padding: 3.5rem 1rem; }
    .separator-line { width: 120px; }
  }

  /* ── CONSULTOR FRAME (offset gold) ───────────────── */
  .consultor-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(201, 169, 97, 0.45);
    transform: translate(14px, -14px);
    pointer-events: none;
    z-index: 0;
  }
  .consultor-frame > * { position: relative; z-index: 1; }

  /* ── GLOBAL MICRO-INTERACTIONS (somente nesta página) ── */
  :global(.btn-primary) span[aria-hidden],
  :global(.btn-outline) span[aria-hidden] {
    transition: transform 220ms ease-out;
    display: inline-block;
  }
  :global(.btn-primary):hover span[aria-hidden],
  :global(.btn-outline):hover span[aria-hidden] {
    transform: translateX(4px);
  }

  /* ── SMOOTH SCROLL ──────────────────────────────── */
  :global(html) { scroll-behavior: smooth; }
</style>
