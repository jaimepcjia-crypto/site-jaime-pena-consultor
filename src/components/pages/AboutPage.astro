---
import Base from '../../layouts/Base.astro';
import LeadForm from '../LeadForm.astro';
import { consultor, whatsappUrl } from '../../config/consultor';
import { useTranslations, localizePath, type Lang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'pt' } = Astro.props;
const t = useTranslations(lang);
const home = localizePath('/', lang);

const difs = [
  { n: '01', t: t('home_dif1_t'), d: t('home_dif1_d') },
  { n: '02', t: t('about_dif2_t'), d: t('home_dif2_d') },
  { n: '03', t: t('home_dif3_t'), d: t('home_dif3_d') },
];
---

<Base lang={lang} title={`${t('seo_about_prefix')} · ${consultor.nome}`} description={t('consultor_bio')}>
  <!-- HERO SOBRE -->
  <section class="pt-40 md:pt-48 pb-20 md:pb-28 bg-cream-50">
    <div class="container-x grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-5 order-2 lg:order-1">
        <p class="eyebrow mb-5 reveal">{t('nav_sobre')}</p>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl leading-[1.02] mb-8 reveal">
          {consultor.nome}.
        </h1>
        <p class="text-lg md:text-xl text-ink leading-relaxed font-light mb-6 reveal">
          {t('consultor_bio')}
        </p>
        <p class="text-ink-500 leading-relaxed reveal">
          {t('sobre_p1')}
        </p>
        <div class="mt-10 grid grid-cols-2 gap-6 reveal">
          <div>
            <p class="eyebrow text-gold-600 mb-2">{t('label_registro')}</p>
            <p class="font-sans text-xl font-medium tracking-wide tabular-nums">{consultor.creci}</p>
          </div>
          <div>
            <p class="eyebrow text-gold-600 mb-2">{t('label_atuacao')}</p>
            <p class="font-serif text-2xl">Salvador / BA</p>
          </div>
        </div>
        <div class="mt-12 flex flex-wrap gap-5 reveal">
          <a href={whatsappUrl(lang)} target="_blank" rel="noopener" class="btn-primary">
            {t('cta_wpp')}
            <span aria-hidden="true">→</span>
          </a>
          <a href={`${home}#empreendimentos`} class="btn-outline">{t('about_cta_ver')}</a>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 reveal">
        <div class="img-zoom-wrap aspect-[4/5] bg-ink-800 relative">
          <img src={consultor.foto} alt={consultor.nome} class="w-full h-full object-cover" loading="eager" />
          <div class="absolute bottom-6 left-6 right-6 bg-cream-50/95 backdrop-blur-sm p-5 md:p-6">
            <p class="eyebrow text-gold-600 mb-2">{t('label_especialista')} · Moura Dubeux</p>
            <p class="font-serif text-2xl md:text-3xl leading-tight">{t('consultor_quote')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="py-20 md:py-28 bg-cream-100">
    <div class="container-x">
      <div class="mb-16 reveal">
        <p class="eyebrow mb-5">{t('about_atendimento_eyebrow')}</p>
        <h2 class="font-serif text-4xl md:text-5xl leading-tight max-w-3xl">
          {t('about_atendimento_title')}
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-10 md:gap-14">
        {difs.map((item) => (
          <div class="reveal">
            <p class="font-serif text-5xl text-gold mb-6">{item.n}</p>
            <h3 class="font-serif text-2xl md:text-3xl leading-tight mb-4">{item.t}</h3>
            <p class="text-ink-500 leading-relaxed">{item.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="py-24 md:py-32 bg-ink text-cream-50">
    <div class="container-x grid lg:grid-cols-12 gap-12 lg:gap-20">
      <div class="lg:col-span-5 reveal">
        <p class="eyebrow text-gold mb-5">{t('nav_contato')}</p>
        <h2 class="font-serif text-4xl md:text-6xl leading-tight mb-8">{t('contato_title_l1')}<br />{t('contato_title_l2')}</h2>
        <div class="space-y-5">
          <a href={whatsappUrl(lang)} target="_blank" rel="noopener" class="flex items-center gap-4 hover:text-gold transition-colors group">
            <span class="w-10 h-10 border border-cream-50/30 group-hover:border-gold rounded-full flex items-center justify-center text-sm transition-colors">W</span>
            <span>
              <span class="block text-[10px] uppercase tracking-widest text-cream-50/50">{t('label_whatsapp')}</span>
              <span class="block">{consultor.whatsappFormatado}</span>
            </span>
          </a>
          <a href={`mailto:${consultor.email}`} class="flex items-center gap-4 hover:text-gold transition-colors group">
            <span class="w-10 h-10 border border-cream-50/30 group-hover:border-gold rounded-full flex items-center justify-center text-sm transition-colors">@</span>
            <span class="break-all">
              <span class="block text-[10px] uppercase tracking-widest text-cream-50/50">{t('label_email')}</span>
              <span class="block">{consultor.email}</span>
            </span>
          </a>
        </div>
      </div>
      <div class="lg:col-span-7 bg-cream-50 text-ink p-8 md:p-12 reveal">
        <h3 class="font-serif text-2xl md:text-3xl mb-2">{t('about_form_title')}</h3>
        <p class="text-ink-500 text-sm mb-8">{t('form_box_sub')}</p>
        <LeadForm lang={lang} />
      </div>
    </div>
  </section>
</Base>
