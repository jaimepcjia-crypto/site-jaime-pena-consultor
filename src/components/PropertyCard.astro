---
import type { Empreendimento } from '../lib/properties';
import { statusBadgesFor, shortLocationFor } from '../lib/properties';
import { useTranslations, localizePath, type Lang } from '../i18n/utils';

interface Props {
  e: Empreendimento;
  index: number;
  lang?: Lang;
}
const { e, index, lang = 'pt' } = Astro.props;
const t = useTranslations(lang);
const statuses = statusBadgesFor(e.slug, lang);
const local = shortLocationFor(e.slug);
const href = localizePath(`/empreendimento/${e.slug}/`, lang);
const img = e.heroImage ?? e.images?.[0];

// Acento dourado para "Últimas Unidades"; demais em creme sobre a foto.
const toneClass = (tone: (typeof statuses)[number]['tone']) =>
  tone === 'available' ? 'text-gold-400' : 'text-cream-50/90';

// Tipologias de quartos (ex.: "Studio, 1 e 2 quartos" / "3 e 4 quartos")
const quartos = e.quartos ?? [];
const quartosParts = [
  ...(e.studio ? [t('card_studio')] : []),
  ...quartos.map((q) => String(q)),
];
// Junta com vírgulas e "e" (conjunção localizada) antes do último item.
const joinParts = (arr: string[]) =>
  arr.length <= 1
    ? (arr[0] ?? '')
    : `${arr.slice(0, -1).join(', ')} ${t('card_and')} ${arr[arr.length - 1]}`;
const quartosWord = quartos.length === 1 && quartos[0] === 1 ? t('card_quarto') : t('card_quartos');
const quartosLabel = quartosParts.length
  ? `${joinParts(quartosParts)}${quartos.length ? ` ${quartosWord}` : ''}`
  : '';

const baseDelay = (index % 10) * 50;
---

<a
  href={href}
  class="reveal property-card group relative block overflow-hidden bg-ink-900"
  style={`--base:${baseDelay}ms`}
>
  <!-- IMAGEM -->
  <div class="img-zoom-wrap absolute inset-0">
    {img && (
      <img
        src={img}
        alt={`${e.title} — ${local}, Salvador`}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover"
      />
    )}
  </div>

  <!-- Gradiente para legibilidade -->
  <span class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/25 to-ink/5 pointer-events-none"></span>

  <!-- Conteúdo sobre a foto -->
  <div class="relative aspect-[4/5] flex flex-col justify-between p-3.5 sm:p-4 md:p-5">

    <!-- TOPO: status -->
    <div class="flex flex-wrap gap-x-2.5 gap-y-1.5">
      {statuses.map((status) => (
        <span class={`inline-block text-[9px] sm:text-[10px] uppercase tracking-widest font-medium px-2 py-1 bg-ink/75 backdrop-blur-sm ${toneClass(status.tone)}`}>
          {status.label}
        </span>
      ))}
    </div>

    <!-- RODAPÉ: local · título · quartos -->
    <div>
      <p class="text-[9px] sm:text-[10px] uppercase tracking-widest text-cream-50/70 font-medium mb-1.5">
        {local} · Salvador
      </p>
      <h3 class="font-serif text-cream-50 leading-[1.05] tracking-tight text-[clamp(1rem,3.4vw,1.45rem)] line-clamp-2">
        {e.title}
      </h3>

      <span class="block h-px w-7 bg-gold/60 mt-2.5 mb-2 group-hover:w-12 transition-[width] duration-500"></span>

      <div class="flex items-center justify-between gap-2">
        {quartosLabel && (
          <span class="quartos-chip inline-block whitespace-nowrap bg-white text-ink font-semibold uppercase leading-none px-1.5 py-1">
            {quartosLabel}
          </span>
        )}
        <span class="ml-auto text-gold opacity-0 -translate-x-1.5 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500" aria-hidden="true">→</span>
      </div>
    </div>
  </div>
</a>

<style>
  .property-card {
    border: 1px solid rgba(201, 169, 97, 0.18);
    transition: transform 0.45s ease, box-shadow 0.5s ease, border-color 0.5s ease;
    container-type: inline-size; /* permite dimensionar a tipologia pela largura do card */
  }

  /* Tipologia: sempre em UMA linha; fonte escala com a largura do card */
  .quartos-chip {
    font-size: clamp(0.5rem, 4.8cqi, 0.7rem);
    letter-spacing: 0.03em;
  }
  .property-card:hover {
    transform: translateY(-3px);
    border-color: rgba(201, 169, 97, 0.85);
    box-shadow:
      0 18px 38px -22px rgba(10, 10, 10, 0.55),
      0 0 0 1px rgba(201, 169, 97, 0.45);
  }

  /* Zoom da foto no hover do card (o :hover do wrap nao dispara pois fica coberto) */
  .property-card:hover .img-zoom-wrap img { transform: scale(1.06); }

  @media (prefers-reduced-motion: reduce) {
    .property-card,
    .property-card:hover { transform: none; transition: none; }
    .img-zoom-wrap img,
    .property-card:hover .img-zoom-wrap img { transition: none; transform: none; }
  }
</style>
