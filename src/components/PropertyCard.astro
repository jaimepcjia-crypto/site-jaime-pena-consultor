---
import type { Empreendimento } from '../lib/properties';
import { statusBadgesFor, shortLocationFor } from '../lib/properties';
import { useTranslations, localizePath, type Lang } from '../i18n/utils';

interface Props {
  e: Empreendimento;
  index: number;
  lang?: Lang;
}
const { e, index, lang = 'pt' } = Astro.props;
const t = useTranslations(lang);
const statuses = statusBadgesFor(e.slug, lang);
const local = shortLocationFor(e.slug);
const href = localizePath(`/empreendimento/${e.slug}/`, lang);
const img = e.heroImage ?? e.images?.[0];

// Status para a tarja: oculta o badge "Últimas Unidades" (tone 'available'),
// mantendo só a informação de entrega/obra. Ex.: "Entrega 1º semestre/31".
const statusLabel = statuses
  .filter((s) => s.tone !== 'available')
  .map((s) => s.label)
  .join(' · ');

// Tipologias de quartos (ex.: "Studio, 1 e 2 quartos" / "3 e 4 quartos")
const quartos = e.quartos ?? [];
const quartosParts = [
  ...(e.studio ? [t('card_studio')] : []),
  ...quartos.map((q) => String(q)),
];
// Junta com vírgulas e "e" (conjunção localizada) antes do último item.
const joinParts = (arr: string[]) =>
  arr.length <= 1
    ? (arr[0] ?? '')
    : `${arr.slice(0, -1).join(', ')} ${t('card_and')} ${arr[arr.length - 1]}`;
const quartosWord = quartos.length === 1 && quartos[0] === 1 ? t('card_quarto') : t('card_quartos');
const quartosLabel = quartosParts.length
  ? `${joinParts(quartosParts)}${quartos.length ? ` ${quartosWord}` : ''}`
  : '';

const baseDelay = (index % 10) * 50;
---

<a
  href={href}
  class="reveal property-card group relative flex flex-col overflow-hidden bg-ink-900"
  style={`--base:${baseDelay}ms`}
>
  <!-- IMAGEM: só o nome do imóvel sobre a foto -->
  <div class="relative aspect-[4/5] shrink-0 overflow-hidden">
    <div class="img-zoom-wrap absolute inset-0">
      {img && (
        <img
          src={img}
          alt={`${e.title} — ${local}, Salvador`}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      )}
    </div>

    <!-- Gradiente para legibilidade do título -->
    <span class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/15 to-transparent pointer-events-none"></span>

    <h3 class="absolute inset-x-0 bottom-0 p-3.5 sm:p-4 md:p-5 font-serif text-cream-50 leading-[1.05] tracking-tight text-[clamp(1rem,3.4vw,1.45rem)] line-clamp-2">
      {e.title}
    </h3>
  </div>

  <!-- PAINEL: extensão preta com Status · Tipologia · Bairro em dourado -->
  <div class="flex flex-col gap-1.5 bg-ink-900 px-3.5 sm:px-4 md:px-5 py-3 border-t border-gold/15">
    {statusLabel && (
      <div class="card-info-row">
        <span class="card-info-label">{t('pp_quick_status')}</span>
        <span class="card-info-value">{statusLabel}</span>
      </div>
    )}
    {quartosLabel && (
      <div class="card-info-row">
        <span class="card-info-label">{t('pp_tipologia_eyebrow')}</span>
        <span class="card-info-value">{quartosLabel}</span>
      </div>
    )}
    {local && (
      <div class="card-info-row">
        <span class="card-info-label">{t('card_label_bairro')}</span>
        <span class="card-info-value">{local}</span>
      </div>
    )}
  </div>
</a>

<style>
  .property-card {
    border: 1px solid rgba(201, 169, 97, 0.18);
    transition: transform 0.45s ease, box-shadow 0.5s ease, border-color 0.5s ease;
    container-type: inline-size; /* permite escalar os textos do painel pela largura do card */
  }

  /* Linhas Status · Tipologia · Bairro: rótulo + valor em dourado */
  .card-info-row {
    display: grid;
    grid-template-columns: minmax(3.5rem, auto) 1fr;
    gap: 0.1rem 0.55rem;
    align-items: baseline;
  }
  .card-info-label {
    font-size: clamp(0.4375rem, 2.3cqi, 0.5625rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    color: rgba(201, 169, 97, 0.55);
  }
  .card-info-value {
    font-size: clamp(0.5625rem, 2.9cqi, 0.75rem);
    line-height: 1.2;
    color: #c9a961; /* dourado */
  }
  .property-card:hover {
    transform: translateY(-3px);
    border-color: rgba(201, 169, 97, 0.85);
    box-shadow:
      0 18px 38px -22px rgba(10, 10, 10, 0.55),
      0 0 0 1px rgba(201, 169, 97, 0.45);
  }

  /* Zoom da foto no hover do card (o :hover do wrap nao dispara pois fica coberto) */
  .property-card:hover .img-zoom-wrap img { transform: scale(1.06); }

  @media (prefers-reduced-motion: reduce) {
    .property-card,
    .property-card:hover { transform: none; transition: none; }
    .img-zoom-wrap img,
    .property-card:hover .img-zoom-wrap img { transition: none; transform: none; }
  }
</style>
