---
import { consultor, whatsappUrl } from '../config/consultor';
import { useTranslations, localizePath, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'pt' } = Astro.props;
const t = useTranslations(lang);
const home = localizePath('/', lang);
---

<footer class="bg-ink text-cream-50 mt-32">
  <div class="container-x py-20 md:py-24 grid md:grid-cols-3 gap-12 md:gap-16">
    <div>
      <h3 class="font-serif text-3xl md:text-4xl leading-tight mb-6">{consultor.nome}</h3>
      <p class="text-cream-50/70 text-sm leading-relaxed max-w-xs">{t('consultor_bioCurta')}</p>
      <p class="mt-6 text-[11px] uppercase tracking-widest text-gold">{consultor.creci}</p>
    </div>

    <div>
      <p class="eyebrow text-gold/80 mb-5">{t('footer_nav_title')}</p>
      <ul class="space-y-3 text-sm">
        <li><a href={home} class="hover:text-gold transition-colors">{t('nav_home')}</a></li>
        <li><a href={`${home}#empreendimentos`} class="hover:text-gold transition-colors">{t('nav_empreendimentos')}</a></li>
        <li><a href={localizePath('/sobre/', lang)} class="hover:text-gold transition-colors">{t('nav_sobre')}</a></li>
        <li><a href={`${home}#contato`} class="hover:text-gold transition-colors">{t('nav_contato')}</a></li>
      </ul>
    </div>

    <div>
      <p class="eyebrow text-gold/80 mb-5">{t('footer_contact_title')}</p>
      <ul class="space-y-3 text-sm">
        <li>
          <a href={whatsappUrl(lang)} target="_blank" rel="noopener" class="hover:text-gold transition-colors">
            WhatsApp · {consultor.whatsappFormatado}
          </a>
        </li>
        <li>
          <a href={`mailto:${consultor.email}`} class="hover:text-gold transition-colors break-all">
            {consultor.email}
          </a>
        </li>
        <li class="text-cream-50/60">{consultor.cidade}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-cream-50/10">
    <div class="container-x py-6 flex flex-col md:flex-row gap-3 items-center justify-between text-[11px] uppercase tracking-widest text-cream-50/40">
      <p>© {new Date().getFullYear()} {consultor.nome} · {consultor.creci}</p>
      <p>{t('footer_rights_suffix')}</p>
    </div>
  </div>
</footer>
