---
import { whatsappUrl, consultor } from '../config/consultor';
---

<a
  href={whatsappUrl()}
  target="_blank"
  rel="noopener"
  aria-label={`Conversar com ${consultor.nome} no WhatsApp`}
  class="fixed bottom-5 right-5 md:bottom-7 md:right-7 z-50 group"
>
  <span
    class="absolute inset-0 rounded-full bg-emerald-500/60 animate-ping opacity-75 group-hover:opacity-0"
  ></span>
  <span
    class="relative flex items-center justify-center w-14 h-14 md:w-16 md:h-16 rounded-full bg-emerald-600 hover:bg-emerald-500 shadow-2xl shadow-emerald-900/40 transition-all duration-300 hover:scale-110"
  >
    <svg viewBox="0 0 32 32" class="w-7 h-7 md:w-8 md:h-8 fill-white" aria-hidden="true">
      <path d="M19.11 17.205c-.372 0-1.088 1.39-1.518 1.39a.633.633 0 0 1-.315-.1c-.802-.402-1.504-.817-2.163-1.447-.545-.516-1.146-1.29-1.46-1.963a.426.426 0 0 1-.073-.215c0-.33.99-.945.99-1.49 0-.143-.73-2.09-.832-2.335-.143-.372-.214-.487-.6-.487-.187 0-.36-.043-.53-.043-.302 0-.53.115-.746.315-.688.645-1.032 1.318-1.06 2.264v.114c-.015.99.472 1.977 1.017 2.78 1.23 1.82 2.506 3.41 4.554 4.34.616.287 2.035.86 2.706.86.474 0 1.34-.226 1.846-.487.31-.16.602-.474.806-.787.255-.39.43-.844.43-1.30 0-.486-.358-.945-.846-1.13l-2.207-.973z"/>
      <path d="M16.045 0c-8.766 0-15.91 7.144-15.91 15.91 0 2.799.745 5.552 2.165 7.964L0 32l8.347-2.205A15.83 15.83 0 0 0 16.045 31.82c8.767 0 15.91-7.143 15.91-15.91S24.812 0 16.045 0zm0 28.992a13.07 13.07 0 0 1-6.66-1.82l-.476-.287-4.95 1.305 1.32-4.83-.314-.503a13.05 13.05 0 0 1-1.99-6.946c0-7.215 5.872-13.086 13.086-13.086 7.215 0 13.087 5.87 13.087 13.085 0 7.215-5.872 13.085-13.087 13.085z"/>
    </svg>
  </span>
