---
import PropertyPage from '../../../components/pages/PropertyPage.astro';
import { empreendimentos } from '../../../lib/properties';
import { NON_DEFAULT_LOCALES, type Lang } from '../../../i18n/utils';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.flatMap((lang) =>
    empreendimentos.map((e) => ({ params: { lang, slug: e.slug } }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
---

<PropertyPage slug={slug} lang={lang} />
