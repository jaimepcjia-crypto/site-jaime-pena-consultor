---
import Base from '../layouts/Base.astro';
import LeadForm from '../components/LeadForm.astro';
import { consultor, whatsappUrl } from '../config/consultor';
---

<Base title={`Sobre · ${consultor.nome}`} description={consultor.bio}>
  <!-- HERO SOBRE -->
  <section class="pt-40 md:pt-48 pb-20 md:pb-28 bg-cream-50">
    <div class="container-x grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-5 order-2 lg:order-1">
        <p class="eyebrow mb-5 reveal">Sobre</p>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl leading-[1.02] mb-8 reveal">
          {consultor.nome}.
        </h1>
        <p class="text-lg md:text-xl text-ink leading-relaxed font-light mb-6 reveal">
          {consultor.bio}
        </p>
        <p class="text-ink-500 leading-relaxed reveal">
          Atuação focada em assessoria especializada — do primeiro briefing à entrega das chaves. Curadoria de empreendimentos Moura Dubeux, esclarecimento de plantas, projetos, condições de pagamento e oportunidades de personalização via MD Store.
        </p>
        <div class="mt-10 grid grid-cols-2 gap-6 reveal">
          <div>
            <p class="eyebrow text-gold-600 mb-2">Registro</p>
            <p class="font-serif text-2xl">{consultor.creci}</p>
          </div>
          <div>
            <p class="eyebrow text-gold-600 mb-2">Atuação</p>
            <p class="font-serif text-2xl">Salvador / BA</p>
          </div>
        </div>
        <div class="mt-12 flex flex-wrap gap-5 reveal">
          <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn-primary">
            Conversar no WhatsApp
            <span aria-hidden="true">→</span>
          </a>
          <a href="/#empreendimentos" class="btn-outline">Ver Empreendimentos</a>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 reveal">
        <div class="img-zoom-wrap aspect-[4/5] bg-ink-800 relative">
          <img src={consultor.foto} alt={consultor.nome} class="w-full h-full object-cover" loading="eager" />
          <div class="absolute bottom-6 left-6 right-6 bg-cream-50/95 backdrop-blur-sm p-5 md:p-6">
            <p class="eyebrow text-gold-600 mb-2">Especialista · Moura Dubeux</p>
            <p class="font-serif text-2xl md:text-3xl leading-tight">"O imóvel certo conta sua história. Meu trabalho é encontrá-lo."</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="py-20 md:py-28 bg-cream-100">
    <div class="container-x">
      <div class="mb-16 reveal">
        <p class="eyebrow mb-5">Atendimento</p>
        <h2 class="font-serif text-4xl md:text-5xl leading-tight max-w-3xl">
          Atendimento especializado, do briefing à entrega das chaves.
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-10 md:gap-14">
        {[
          { n: '01', t: 'Curadoria personalizada', d: 'Conheço cada empreendimento Moura Dubeux em Salvador — plantas, posições, vistas e oportunidades. Indico o que faz sentido para o seu perfil.' },
          { n: '02', t: 'Acesso direto à construtora', d: 'Negociação ágil, condições especiais e participação no programa MD Store de personalização de plantas e acabamentos.' },
          { n: '03', t: 'Acompanhamento integral', d: 'Estou presente em cada etapa: visita ao stand, fechamento, acompanhamento de obra e suporte pós-entrega.' },
        ].map((item) => (
          <div class="reveal">
            <p class="font-serif text-5xl text-gold mb-6">{item.n}</p>
            <h3 class="font-serif text-2xl md:text-3xl leading-tight mb-4">{item.t}</h3>
            <p class="text-ink-500 leading-relaxed">{item.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="py-24 md:py-32 bg-ink text-cream-50">
    <div class="container-x grid lg:grid-cols-12 gap-12 lg:gap-20">
      <div class="lg:col-span-5 reveal">
        <p class="eyebrow text-gold mb-5">Contato</p>
        <h2 class="font-serif text-4xl md:text-6xl leading-tight mb-8">Vamos<br />conversar.</h2>
        <div class="space-y-5">
          <a href={whatsappUrl()} target="_blank" rel="noopener" class="flex items-center gap-4 hover:text-gold transition-colors group">
            <span class="w-10 h-10 border border-cream-50/30 group-hover:border-gold rounded-full flex items-center justify-center text-sm transition-colors">W</span>
            <span>
              <span class="block text-[10px] uppercase tracking-widest text-cream-50/50">WhatsApp</span>
              <span class="block">{consultor.whatsappFormatado}</span>
            </span>
          </a>
          <a href={`mailto:${consultor.email}`} class="flex items-center gap-4 hover:text-gold transition-colors group">
            <span class="w-10 h-10 border border-cream-50/30 group-hover:border-gold rounded-full flex items-center justify-center text-sm transition-colors">@</span>
            <span class="break-all">
              <span class="block text-[10px] uppercase tracking-widest text-cream-50/50">E-mail</span>
              <span class="block">{consultor.email}</span>
            </span>
          </a>
        </div>
      </div>
      <div class="lg:col-span-7 bg-cream-50 text-ink p-8 md:p-12 reveal">
        <h3 class="font-serif text-2xl md:text-3xl mb-2">Solicitar contato</h3>
        <p class="text-ink-500 text-sm mb-8">Retorno em até 24h úteis.</p>
        <LeadForm />
      </div>
    </div>
  </section>
</Base>
