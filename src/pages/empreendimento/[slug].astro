---
import PropertyPage from '../../components/pages/PropertyPage.astro';
import { empreendimentos } from '../../lib/properties';

export function getStaticPaths() {
  return empreendimentos.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
---

<PropertyPage slug={slug!} lang="pt" />
